<section class="featured-brands container mb-6">
  <div class="featured-brands__header mb-6">
    <p class="h1 featured-brands__title h1 font-weight-normal m-0">
      Marcas <span class="font-weight-bold underline-rpairme-lime">destacadas</span>
    </p>
  </div>

  <div class="featured-brands__list row">
    <div class="featured-brands__item col-12 col-md-4 mb-3">
      <a class="featured-brands__link d-block" href="#">
        <img
          class="featured-brands__image img-fluid w-100"
          src="/img/brands/apple.png"
          alt="{l s='Marca destacada 1' d='Shop.Theme.Catalog'}"
          loading="lazy"
        >
      </a>
    </div>

    <div class="featured-brands__item col-12 col-md-4 mb-3">
      <a class="featured-brands__link d-block" href="#">
        <img
          class="featured-brands__image img-fluid w-100"
          src="/img/brands/realme.png"
          alt="{l s='Marca destacada 2' d='Shop.Theme.Catalog'}"
          loading="lazy"
        >
      </a>
    </div>

    <div class="featured-brands__item col-12 col-md-4 mb-3">
      <a class="featured-brands__link d-block" href="#">
        <img
          class="featured-brands__image img-fluid w-100"
          src="/img/brands/xiaomi.png"
          alt="{l s='Marca destacada 3' d='Shop.Theme.Catalog'}"
          loading="lazy"
        >
      </a>
    </div>
